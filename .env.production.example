# ============================================
# CONFIGURATION DE PRODUCTION - AIGLE ROYALE
# ============================================

# Base de données PostgreSQL
DATABASE_URL="postgresql://aigle_user:CHANGEZ_MOT_DE_PASSE@localhost:5432/aigle_royale?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="https://travelia.afrika-connect.io"
# IMPORTANT: Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="GENERER_UN_SECRET_FORT_ICI"

# CRON Secret (protection des endpoints planifiés)
# IMPORTANT: Générer avec: openssl rand -base64 32
CRON_SECRET="GENERER_UN_SECRET_FORT_ICI"

# Devise (conversion FC -> USD)
NEXT_PUBLIC_USD_FC_RATE=600
NEXT_PUBLIC_WIFI_PASS_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_PIECE_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_OVERWEIGHT_PRICE_FC_PER_KG=200

# Configuration Production
NODE_ENV=production

# IMPORTANT: Désactiver les comptes démo en production
DEMO_SEED=false
ADMIN_PASSWORD=""

# APIs de paiement
MOBILE_MONEY_API_KEY=""
CARD_PAYMENT_API_KEY=""

# Email Provider (SendGrid, Mailgun, etc.)
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM="noreply@travelia.afrika-connect.io"

# SMS Provider (Twilio, etc.)
SMS_PROVIDER_API_KEY=""
SMS_FROM="+225XXXXXXXXXX"
