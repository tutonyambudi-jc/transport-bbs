# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aigle_royale?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-a-long-random-secret"

# Cron secret: used to protect scheduled endpoints (set a strong value in production)
CRON_SECRET="replace-with-a-strong-random-secret"

# Demo seeding control: set to 'true' to create demo accounts (only for local/dev)
# When enabled you can set `ADMIN_PASSWORD`, otherwise demo users are skipped.
DEMO_SEED="false"
ADMIN_PASSWORD=""

# Devise (affichage) - conversion XOF -> USD
# Exemple: 1 USD ≈ 600 XOF (ajustez selon votre taux)
NEXT_PUBLIC_USD_XOF_RATE=600
NEXT_PUBLIC_WIFI_PASS_PRICE_XOF=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_PIECE_PRICE_XOF=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_OVERWEIGHT_PRICE_XOF_PER_KG=200

# Payment Providers (optionnel)
MOBILE_MONEY_API_KEY=""
CARD_PAYMENT_API_KEY=""

